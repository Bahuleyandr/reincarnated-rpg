{
  "_meta": {
    "license": "CC BY-NC 4.0",
    "version": 1,
    "authoredOn": "2026-05-04",
    "notes": "Daily and weekly objectives. Each entry has a JSON-DSL predicate that, when matched against the per-turn event slice, increments progress by 1. completed_at flips when progress meets target; reward_claimed_at fills in after explicit claim. periodKey is 'YYYY-MM-DD' (daily) or 'YYYY-Www' (weekly)."
  },
  "objectives": [
    {
      "id": "daily-three-turns",
      "label": "Three Turns Today",
      "description": "Take three turns in any form before the day ends (UTC).",
      "period": "daily",
      "target": 3,
      "predicate": { "type": "eventOfKind", "kind": "turn.begun" },
      "relevantKinds": ["turn.begun"],
      "reward": { "kind": "energy", "amount": 3 }
    },
    {
      "id": "daily-survive-once",
      "label": "Survive a Run",
      "description": "Finish a run with status 'won'.",
      "period": "daily",
      "target": 1,
      "predicate": {
        "type": "eventWith",
        "match": { "kind": "session.ended", "reason": "win" }
      },
      "relevantKinds": ["session.ended"],
      "reward": { "kind": "energy", "amount": 5 }
    },
    {
      "id": "daily-die-once",
      "label": "Die With Grace",
      "description": "End a run in death. The cycle smiles.",
      "period": "daily",
      "target": 1,
      "predicate": {
        "type": "eventWith",
        "match": { "kind": "session.ended", "reason": "death" }
      },
      "relevantKinds": ["session.ended"],
      "reward": { "kind": "energy", "amount": 2 }
    },
    {
      "id": "daily-friend",
      "label": "Bend Toward Someone",
      "description": "Bring an NPC's relationship up by 1.",
      "period": "daily",
      "target": 1,
      "predicate": {
        "type": "eventWith",
        "match": { "kind": "relationship.updated", "delta": { "$gte": 1 } }
      },
      "relevantKinds": ["relationship.updated"],
      "reward": { "kind": "energy", "amount": 2 }
    },
    {
