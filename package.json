{
  "name": "reincarnated-rpg",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "dev:up": "bash scripts/dev-up.sh",
    "dev:down": "bash scripts/dev-down.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "node scripts/migrate-prod.mjs",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:prod": "node scripts/seed-runtime.mjs",
    "test:db": "tsx scripts/check-test-db.ts",
    "content:validate": "tsx scripts/validate-content.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "wedge:clip": "tsx scripts/wedge-clip.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPatterns=tests/unit",
    "test:integration": "npm run test:db && jest --testPathPatterns=tests/integration --runInBand --testTimeout=15000",
    "test:e2e": "playwright test",
    "ci:local": "bash scripts/ci-local.sh",
    "ci:local:fast": "bash scripts/ci-local.sh --fast",
    "eval": "tsx eval/runner.ts",
    "smoke": "node scripts/smoke.mjs",
    "report:ai-cost": "tsx scripts/report-ai-cost.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "next": "16.2.4",
    "pgvector": "^0.2.1",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "uuid": "^14.0.0",
    "voyageai": "^0.2.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
