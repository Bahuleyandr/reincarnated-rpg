# Copy to .env.local and fill in. .env.local is gitignored.

# --- Database -----------------------------------------------------------------
# Local dev defaults to the docker-compose Postgres on port 5433.
#
# WSL2 + Docker-in-WSL gotcha: Windows-side localhost forwarding to a WSL2
# container is unreliable on some hosts. If `npm run db:migrate` cannot connect
# to localhost:5433, run `wsl hostname -I` and use that IP here.
DATABASE_URL=postgres://reincarnated:reincarnated@localhost:5433/reincarnated

# --- AI providers (M2 day 8+) -------------------------------------------------
# Leave blank during M1; the template narrator runs without them.
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# --- Auth ---------------------------------------------------------------------
# 32 random bytes (any encoding). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# --- Narrator selection -------------------------------------------------------
# `template` = phrase-bank, deterministic, no API costs (default through M1).
# `remote`   = Anthropic SDK (Sonnet 4.6 narration, Haiku 4.5 classifier).
NARRATOR=template
