# Copy to .env.local and fill in. .env.local is gitignored.

# --- Database -----------------------------------------------------------------
# Local dev defaults to the docker-compose Postgres on port 5433.
#
# WSL2 + Docker-in-WSL gotcha: Windows-side localhost forwarding to a WSL2
# container is unreliable on some hosts. If `npm run db:migrate` cannot connect
# to localhost:5433, run `wsl hostname -I` and use that IP here.
DATABASE_URL=postgres://reincarnated:reincarnated@localhost:5433/reincarnated

# --- AI providers (M2 day 8+) -------------------------------------------------
# Provider selection: "anthropic" (default) or "openai-compatible".
# Leave blank during M1; the template narrator runs without any keys.
AI_PROVIDER=anthropic

# Default provider — Anthropic Sonnet 4.6 narration + Haiku 4.5 classifier/tone.
ANTHROPIC_API_KEY=

# Voyage embeddings for episodic memory (M2 day 10+).
VOYAGE_API_KEY=

# OpenAI-compatible alternative (OpenRouter, local Ollama, vLLM, etc.).
# Set AI_PROVIDER=openai-compatible to route narrator + classifier here.
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=anthropic/claude-sonnet-4-6

# --- Auth ---------------------------------------------------------------------
# 32 random bytes (any encoding). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# --- Narrator selection -------------------------------------------------------
# `template` = phrase-bank, deterministic, no API costs (default through M1).
# `remote`   = Anthropic SDK (Sonnet 4.6 narration, Haiku 4.5 classifier).
NARRATOR=template
